<Window x:Class="Desktop_Creatures.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"

        ShowInTaskbar="False"
        Width="128"
        Height="128">
    <Grid>
        
        <StackPanel Margin="12">
            <Button Content="Spawn Rat"
                    Click="SpawnRat_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Spawn Eagle"
                    Click="SpawnEagle_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Exit"
                    Click="Exit_Click"
                    Margin="0,0,0,8"/>
            <ToggleButton x:Name="AlwaysOnTopToggle"
              Content="Always On Top"
              Checked="AlwaysOnTopToggle_Checked"
              Unchecked="AlwaysOnTopToggle_Unchecked"/>
        </StackPanel>

    </Grid>
</Window>
